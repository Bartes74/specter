{
  "name": "spec-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Spec Generator — lokalna aplikacja webowa generująca specyfikacje projektów (requirements.md, design.md, tasks.md) zoptymalizowane pod narzędzia AI",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:property": "vitest run --reporter=verbose **/*.property.ts",
    "test:e2e": "playwright test",
    "tutorials:verify": "tsx scripts/verify-tutorials.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/generative-ai": "^0.21.0",
    "clsx": "^2.1.1",
    "diff": "^7.0.0",
    "next": "^15.0.0",
    "next-intl": "^3.26.0",
    "openai": "^4.77.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "tailwind-merge": "^3.5.0",
    "tiktoken": "^1.0.18",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.3",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "fast-check": "^3.23.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
